<Window x:Class="_315F_SlidingTiles.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:viewModels="clr-namespace:_315F_SlidingTiles.ViewModels"
        xmlns:controls="clr-namespace:_315F_SlidingTiles.Controls"
        mc:Ignorable="d"
        d:DataContext="{d:DesignInstance Type=viewModels:PuzzleViewModel}"
        Title="MainWindow"
        Width="1200" Height="1200">

    <Grid>
        <Canvas Width="380" Height="380">

            <ItemsControl ItemsSource="{Binding Tiles}">

                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <Canvas />
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>

                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <controls:TileControl
                            Command="{Binding DataContext.TileClickCommand, RelativeSource={RelativeSource AncestorType=Window}}" />
                    </DataTemplate>
                </ItemsControl.ItemTemplate>

            </ItemsControl>

        </Canvas>
    </Grid>
</Window>